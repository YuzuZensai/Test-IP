{
    "name": "ip-test",
    "type": "module",
    "scripts": {
        "start": "bun run src/index.ts",
        "dev": "bun --hot src/index.ts",
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "lint": "biome lint .",
        "format": "biome format .",
        "format:fix": "biome format --write .",
        "check": "bun run typecheck && biome check . && bun test",
        "fix": "biome check --write ."
    },
    "dependencies": {
        "elysia": "^1.4.29"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.3",
        "@types/bun": "^1.3.14",
        "typescript": "^7.0.2"
    }
}
